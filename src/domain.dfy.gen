function wellFormedStrict(e: Event): bool
{
  (wellFormed(e) && uniqueIds(e.participants))
}

function initEventStrict(id: string, title: string, numSlots: int): bool
  requires (numSlots >= 0)
{
  true
}

lemma initEventStrict_ensures(id: string, title: string, numSlots: int)
  requires (numSlots >= 0)
  ensures wellFormedStrict(initEvent(id, title, numSlots))
{
}

function applyOpPreservesStrict(e: Event, op: Op): bool
  requires wellFormedStrict(e)
  requires (op.join? ==> !(idTaken(e.participants, op.participant.id)))
{
  true
}

lemma applyOpPreservesStrict_ensures(e: Event, op: Op)
  requires wellFormedStrict(e)
  requires (op.join? ==> !(idTaken(e.participants, op.participant.id)))
  ensures wellFormedStrict(applyOp(e, op))
{
}

function freshJoinIds(e: Event, ops: seq<Op>): bool
  decreases |ops|
{
  ((|ops| == 0) || (if (ops[0].join? && idTaken(e.participants, ops[0].participant.id)) then false else freshJoinIds(applyOp(e, ops[0]), ops[1..])))
}

function replayPreservesStrict(e: Event, ops: seq<Op>): bool
  requires wellFormedStrict(e)
  requires freshJoinIds(e, ops)
  decreases |ops|
{
  true
}

lemma replayPreservesStrict_ensures(e: Event, ops: seq<Op>)
  requires wellFormedStrict(e)
  requires freshJoinIds(e, ops)
  ensures wellFormedStrict(replay(e, ops))
