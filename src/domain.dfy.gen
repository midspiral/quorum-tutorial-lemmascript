function applyOp(e: Event, op: Op): Event
{
  match op {
    case join(i_op_participant) =>
      if (|i_op_participant.avail| != e.numSlots) then
        e
      else
        e.(participants := (e.participants + [i_op_participant]))
    case paint(i_op_pid, i_op_avail, i_op_ts) =>
      if (|i_op_avail| != e.numSlots) then
        e
      else
        e.(participants := setAvailLWW(e.participants, i_op_pid, i_op_avail, i_op_ts))
  }
}

